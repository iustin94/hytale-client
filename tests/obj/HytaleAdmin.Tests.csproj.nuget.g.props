  </ImportGroup>
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Pkgxunit_analyzers Condition=" '$(Pkgxunit_analyzers)' == '' ">/home/iustinian/.nuget/packages/xunit.analyzers/1.18.0</Pkgxunit_analyzers>
    <PkgStride_Core Condition=" '$(PkgStride_Core)' == '' ">/home/iustinian/.nuget/packages/stride.core/4.3.0.2507</PkgStride_Core>
    <PkgMicrosoft_CodeAnalysis_Analyzers Condition=" '$(PkgMicrosoft_CodeAnalysis_Analyzers)' == '' ">/home/iustinian/.nuget/packages/microsoft.codeanalysis.analyzers/3.3.4</PkgMicrosoft_CodeAnalysis_Analyzers>
    <PkgStride_Core_Assets_CompilerApp Condition=" '$(PkgStride_Core_Assets_CompilerApp)' == '' ">/home/iustinian/.nuget/packages/stride.core.assets.compilerapp/4.3.0.2507</PkgStride_Core_Assets_CompilerApp>
